  "projectType": "cli-tool",
  "projectName": "CoW Protocol Watch Tower",
  "projectDescription": "A standalone watch tower monitoring blockchain events for CoW Protocol programmatic orders and posting them to the OrderBook API",
  "theme": "aspen",
