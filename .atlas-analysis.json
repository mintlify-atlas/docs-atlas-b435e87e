  "keyFeatures": [
    "Monitors blockchain events for conditional orders",
    "Posts discrete orders to CoW Protocol OrderBook API",
    "Supports multiple EVM chains (Ethereum, Arbitrum, Gnosis, Base, etc.)",
    "LevelDB-based registry with ACID guarantees",
    "REST API for version info, config, and database dumps",
    "Prometheus metrics integration",
    "Docker and DAppNode deployment support",
    "Flexible filter policies for orders, owners, and handlers",
    "Configurable logging with module-level control",
    "Slack notifications for error monitoring"
  ],
  "publicApiSurface": [
    "run - Run the watch-tower in monitoring mode",
    "dump-db - Dump database contents as JSON",
    "--config-path - Path to chain configuration file",
    "--database-path - Path to the LevelDB database",
    "--log-level - Set logging verbosity",
    "--dry-run - Run without publishing orders",
    "--one-shot - Run once and exit",
    "--disable-api - Disable the REST API server",
    "--api-port - Configure REST API port (default 8080)",
    "--only-owner - Monitor specific safe addresses",
    "--slack-webhook - Slack webhook URL for notifications",
    "GET /api/version - Get version information",
    "GET /api/config - Get current configuration",
    "GET /api/dump/:chainId - Dump database for chain",
    "GET /metrics - Prometheus metrics endpoint"
  ]
}
